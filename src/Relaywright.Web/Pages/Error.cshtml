@page
@model Relaywright.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="page">
    <section class="panel">
        <h1>Error</h1>
        <p>An unexpected error occurred while processing the request.</p>
        @if (!string.IsNullOrWhiteSpace(Model.RequestId))
        {
            <p class="muted">Request ID: @Model.RequestId</p>
        }
    </section>
</section>
