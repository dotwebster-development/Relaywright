@page
@model Relaywright.Web.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<section class="page narrow">
    <section class="panel">
        <h1>Change Password</h1>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <p class="status">@Model.StatusMessage</p>
        }

        <form method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="status error"></div>
            <label>
                <span>Current Password</span>
                <input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" />
            </label>
            <label>
                <span>New Password</span>
                <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
            </label>
            <label>
                <span>Confirm Password</span>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
            </label>
            <div class="actions">
                <button type="submit">Update Password</button>
            </div>
        </form>
    </section>
</section>
