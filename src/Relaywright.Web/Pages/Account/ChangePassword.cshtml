@page
@model Relaywright.Web.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<section class="page narrow">
    <section class="panel">
        <h1>Change Password</h1>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <p class="status">@Model.StatusMessage</p>
        }

        <form method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="status error"></div>
            <div class="auth-panel">
                <strong>Password Requirements</strong>
                <ul class="compact-list">
                    @foreach (var requirement in Model.PasswordPolicy.Requirements)
                    {
                        <li>@requirement</li>
                    }
                </ul>
            </div>
            <label>
                <span>Current Password</span>
                <input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" />
            </label>
            <label>
                <span>New Password</span>
                <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
            </label>
            <label>
                <span>Confirm Password</span>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
            </label>
            <div class="actions">
                <button type="submit">Update Password</button>
            </div>
        </form>
    </section>

    <section class="panel">
        <h2>Login Activity</h2>
        <dl class="kv">
            <dt>Last Successful Login</dt>
            <dd>
                @if (Model.LoginActivity.LastSuccessfulLogin is null)
                {
                    <span>Not available</span>
                }
                else
                {
                    <span>@Model.LoginActivity.LastSuccessfulLogin.OccurredUtc.ToLocalTime().ToString("g")</span>
                    <span class="muted">from @(Model.LoginActivity.LastSuccessfulLogin.RemoteIpAddress ?? "unknown IP")</span>
                }
            </dd>
            <dt>Last Failed Login</dt>
            <dd>
                @if (Model.LoginActivity.LastFailedLogin is null)
                {
                    <span>None recorded</span>
                }
                else
                {
                    <span>@Model.LoginActivity.LastFailedLogin.OccurredUtc.ToLocalTime().ToString("g")</span>
                    <span class="muted">from @(Model.LoginActivity.LastFailedLogin.RemoteIpAddress ?? "unknown IP")</span>
                }
            </dd>
            <dt>Failed 24h</dt>
            <dd>@Model.LoginActivity.FailedLast24Hours</dd>
            <dt>Failed 7d</dt>
            <dd>@Model.LoginActivity.FailedLast7Days</dd>
            <dt>Security Logs</dt>
            <dd><a asp-page="/Logs/Index" asp-route-category="Security" asp-route-search="Admin sign-in">Review admin sign-in events</a></dd>
        </dl>
    </section>

    @if (Model.SessionSummary is not null)
    {
        <section class="panel">
            <h2>Current Session</h2>
            <dl class="kv">
                <dt>User</dt>
                <dd>@Model.SessionSummary.UserName</dd>
                <dt>Cookie Type</dt>
                <dd>@Model.SessionSummary.PersistenceLabel</dd>
                <dt>Issued</dt>
                <dd>@(Model.SessionSummary.IssuedUtc?.ToLocalTime().ToString("g") ?? "Not available")</dd>
                <dt>Expires</dt>
                <dd>@(Model.SessionSummary.ExpiresUtc?.ToLocalTime().ToString("g") ?? "Browser session")</dd>
                <dt>Secure Policy</dt>
                <dd>@Model.SessionSummary.SecurePolicyLabel</dd>
                <dt>SameSite</dt>
                <dd>@Model.SessionSummary.SameSite</dd>
                <dt>HTTP Only</dt>
                <dd>@(Model.SessionSummary.HttpOnly ? "Yes" : "No")</dd>
                <dt>Sliding Expiration</dt>
                <dd>@(Model.SessionSummary.SlidingExpiration ? "Enabled" : "Disabled")</dd>
                <dt>Stamp Validation</dt>
                <dd>@Model.SessionSummary.SecurityStampValidationLabel</dd>
            </dl>
            <form method="post" asp-page-handler="SignOutAllSessions" class="actions">
                <button type="submit" class="secondary-button">Sign Out All Sessions</button>
            </form>
        </section>
    }

    <section class="panel">
        <h2>Account Recovery</h2>
        <div class="auth-panel">
            <ul class="compact-list">
                @foreach (var item in Model.RecoveryGuidance)
                {
                    <li><strong>@item.Label:</strong> @item.Detail</li>
                }
            </ul>
        </div>
    </section>
</section>
