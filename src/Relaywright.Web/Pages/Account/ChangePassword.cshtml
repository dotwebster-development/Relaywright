@page
@model Relaywright.Web.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<section class="page narrow">
    <section class="panel">
        <h1>Change Password</h1>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <p class="status">@Model.StatusMessage</p>
        }

        <form method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="status error"></div>
            <div class="auth-panel">
                <strong>Password Requirements</strong>
                <ul class="compact-list">
                    @foreach (var requirement in Model.PasswordPolicy.Requirements)
                    {
                        <li>@requirement</li>
                    }
                </ul>
            </div>
            <label>
                <span>Current Password</span>
                <input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" />
            </label>
            <label>
                <span>New Password</span>
                <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
            </label>
            <label>
                <span>Confirm Password</span>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
            </label>
            <div class="actions">
                <button type="submit">Update Password</button>
            </div>
        </form>
    </section>

    @if (Model.SessionSummary is not null)
    {
        <section class="panel">
            <h2>Current Session</h2>
            <dl class="kv">
                <dt>User</dt>
                <dd>@Model.SessionSummary.UserName</dd>
                <dt>Cookie Type</dt>
                <dd>@Model.SessionSummary.PersistenceLabel</dd>
                <dt>Issued</dt>
                <dd>@(Model.SessionSummary.IssuedUtc?.ToLocalTime().ToString("g") ?? "Not available")</dd>
                <dt>Expires</dt>
                <dd>@(Model.SessionSummary.ExpiresUtc?.ToLocalTime().ToString("g") ?? "Browser session")</dd>
                <dt>Secure Policy</dt>
                <dd>@Model.SessionSummary.SecurePolicyLabel</dd>
                <dt>SameSite</dt>
                <dd>@Model.SessionSummary.SameSite</dd>
                <dt>HTTP Only</dt>
                <dd>@(Model.SessionSummary.HttpOnly ? "Yes" : "No")</dd>
                <dt>Sliding Expiration</dt>
                <dd>@(Model.SessionSummary.SlidingExpiration ? "Enabled" : "Disabled")</dd>
                <dt>Stamp Validation</dt>
                <dd>@Model.SessionSummary.SecurityStampValidationLabel</dd>
            </dl>
        </section>
    }
</section>
