@page
@model Relaywright.Web.Pages.Account.LoginModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<section class="page narrow">
    <section class="panel">
        <h1>Login</h1>

        <form method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="status error"></div>
            <input asp-for="Input.ReturnUrl" type="hidden" />
            <label>
                <span>User Name</span>
                <input asp-for="Input.UserName" autocomplete="username" />
            </label>
            <label>
                <span>Password</span>
                <input asp-for="Input.Password" type="password" autocomplete="current-password" />
            </label>
            <label class="switch-control">
                <input asp-for="Input.RememberMe" type="checkbox" />
                <span class="switch-control-track" aria-hidden="true"></span>
                <span>Remember me</span>
            </label>
            <div class="actions">
                <button type="submit">Sign In</button>
            </div>
        </form>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="surface-status">
            <p class="status error">@Model.ErrorMessage</p>
        </div>
    }
</section>
