@page
@model Relaywright.Web.Pages.Diagnostics.TestEmailModel
@{
    ViewData["Title"] = "Diagnostic Test Email";
}

<section class="page">
    <header class="page-header">
        <div class="page-header-copy">
            <p class="page-eyebrow">Diagnostics</p>
            <h1>Test Email</h1>
            <p class="page-summary">Send a one-off test message through the configured upstream relay and review the diagnostic event trail for that submission directly on this page.</p>
        </div>
    </header>

    @if (Model.Result is not null)
    {
        <p class="status @(Model.Result.Succeeded ? "ok" : "error")">@Model.Result.Message</p>
    }

    <section class="panel">
        <h2>Compose Test Email</h2>
        <form method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="status error"></div>
            <label>
                <span>From</span>
                <input asp-for="Input.FromAddress" />
            </label>
            <label>
                <span>To</span>
                <input asp-for="Input.ToAddress" />
            </label>
            <label>
                <span>Subject</span>
                <input asp-for="Input.Subject" />
            </label>
            <label>
                <span>Body</span>
                <textarea asp-for="Input.Body" rows="8"></textarea>
            </label>
            <div class="actions">
                <button type="submit">Send Test Email</button>
            </div>
        </form>
    </section>

    <section class="panel">
        <h2>Latest Test Run Log</h2>

        @if (Model.RunEvents.Count == 0)
        {
            <p class="muted">No diagnostic test-email run has been sent in this page session yet.</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Severity</th>
                            <th>Message</th>
                            <th>Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.RunEvents)
                    {
                        <tr>
                            <td>@item.OccurredUtc.ToLocalTime()</td>
                            <td><span class="status-badge severity-@(item.Severity.ToString().ToLowerInvariant())">@item.Severity</span></td>
                            <td>@item.Message</td>
                            <td>@item.Detail</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel">
        <h2>Recent Test Email Runs</h2>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Started</th>
                        <th>Result</th>
                        <th>Message</th>
                        <th>Stages</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var run in Model.RecentRuns)
                {
                    <tr>
                        <td>@run.StartedUtc.ToLocalTime()</td>
                        <td><span class="status-badge @(run.Succeeded == true ? "status-delivered" : run.Succeeded == false ? "status-failed" : "status-inprogress")">@(run.Succeeded is null ? "Running" : run.Succeeded.Value ? "Succeeded" : "Failed")</span></td>
                        <td>@run.Message</td>
                        <td>
                            @foreach (var stage in run.Stages.OrderBy(x => x.Sequence))
                            {
                                <div class="stage-line">
                                    <span class="status-badge status-@(stage.Status == DiagnosticStageStatus.Succeeded ? "delivered" : stage.Status == DiagnosticStageStatus.Failed ? "failed" : stage.Status == DiagnosticStageStatus.Skipped ? "disabled" : "inprogress")">@stage.Status</span>
                                    <strong>@stage.Name</strong>
                                    <span>@stage.ElapsedMilliseconds ms</span>
                                    <span>@stage.Message</span>
                                </div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>
