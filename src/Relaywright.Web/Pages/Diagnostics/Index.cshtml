@page
@model Relaywright.Web.Pages.Diagnostics.IndexModel
@{
    ViewData["Title"] = "Diagnostics";
}

<section class="page">
    <header class="page-header">
        <div class="page-header-copy">
            <p class="page-eyebrow">Diagnostics</p>
            <h1>Diagnostics</h1>
            <p class="page-summary">Confirm the current upstream relay target and run a direct connection test from this host without leaving the admin interface.</p>
        </div>
    </header>

    <div class="surface-toolbar">
        <div class="toolbar-right">
            <div class="page-actions">
                <a asp-page="/Diagnostics/TestEmail">Open Test Email</a>
            </div>
        </div>
    </div>

    <section class="panel">
        <h2>Connectivity Test</h2>
        <form method="post">
            <button type="submit">Test Upstream Connection</button>
        </form>

        @if (Model.Result is not null)
        {
            <p class="status @(Model.Result.Succeeded ? "ok" : "error")">@Model.Result.Message</p>
            @if (!string.IsNullOrWhiteSpace(Model.Result.Recommendation))
            {
                <p class="field-hint">Next action: @Model.Result.Recommendation</p>
            }
        }
    </section>

    <section class="panel">
        <h2>Recent Connectivity Runs</h2>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Started</th>
                        <th>Result</th>
                        <th>Message</th>
                        <th>Stages</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var run in Model.RecentRuns)
                {
                    <tr>
                        <td>@run.StartedUtc.ToLocalTime()</td>
                        <td><span class="status-badge @(run.Succeeded == true ? "status-delivered" : run.Succeeded == false ? "status-failed" : "status-inprogress")">@(run.Succeeded is null ? "Running" : run.Succeeded.Value ? "Succeeded" : "Failed")</span></td>
                        <td>@run.Message</td>
                        <td>
                            @foreach (var stage in run.Stages.OrderBy(x => x.Sequence))
                            {
                                <div class="stage-line">
                                    <span class="status-badge status-@(stage.Status == DiagnosticStageStatus.Succeeded ? "delivered" : stage.Status == DiagnosticStageStatus.Failed ? "failed" : stage.Status == DiagnosticStageStatus.Skipped ? "disabled" : "inprogress")">@stage.Status</span>
                                    <strong>@stage.Name</strong>
                                    <span>@stage.ElapsedMilliseconds ms</span>
                                    <span>@stage.Message</span>
                                </div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>
