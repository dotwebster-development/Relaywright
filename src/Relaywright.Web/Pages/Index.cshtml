@page
@model Relaywright.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page">
    <header class="page-header">
        <div class="page-header-copy">
            <p class="page-eyebrow">Overview</p>
            <h1>Dashboard</h1>
            <p class="page-summary">Monitor relay health, control outbound delivery, review the active upstream configuration, and keep an eye on recent operational events without leaving the main workspace.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="surface-status flash-status" data-flash-status role="status" aria-live="polite">
            <p class="status">@Model.StatusMessage</p>
        </div>
    }

    @if (Model.RuntimeStatus.RestartRequired)
    {
        <div class="surface-status">
            <section class="status warning">
                <strong>Restart required.</strong>
                <span>@Model.RuntimeStatus.RestartReason</span>
                @if (Model.RuntimeStatus.RestartRequestedUtc is not null)
                {
                    <span>Requested @Model.RuntimeStatus.RestartRequestedUtc.Value.ToLocalTime().ToString("g") by @(Model.RuntimeStatus.RestartRequestedBy ?? "system").</span>
                }
                <span>@(Model.RuntimeStatus.RestartSupported ? "A graceful restart has been requested." : "Restart Relaywright from the host service manager to apply the change.")</span>
            </section>
        </div>
    }

    @if (Model.AttentionItems.Count > 0)
    {
        <section class="panel attention-panel">
            <h2>Needs Attention</h2>
            <div class="attention-list">
                @foreach (var item in Model.AttentionItems)
                {
                    <div class="attention-item">
                        <span class="status-badge @item.BadgeClass">@item.Title</span>
                        <span>@item.Detail</span>
                    </div>
                }
            </div>
        </section>
    }

    <div class="stats-grid">
        <article class="stat">
            <h2>Pending</h2>
            <strong>@Model.PendingCount</strong>
            <p>Accepted messages waiting for first delivery.</p>
        </article>
        <article class="stat">
            <h2>Retrying</h2>
            <strong>@Model.RetryCount</strong>
            <p>Messages scheduled for another upstream attempt.</p>
        </article>
        <article class="stat">
            <h2>Failed</h2>
            <strong>@Model.FailedCount</strong>
            <p>Queue items that need review or operator action.</p>
        </article>
        <article class="stat">
            <h2>Delivered Today</h2>
            <strong>@Model.DeliveredTodayCount</strong>
            <p>Successful deliveries recorded since midnight.</p>
        </article>
    </div>

    <div class="surface-grid two-up">
        <section class="panel">
            <h2>Traffic Metrics</h2>
            <dl class="kv">
                <dt>Accepted 24h</dt>
                <dd>@Model.Metrics.AcceptedLast24Hours</dd>
                <dt>Delivered 24h</dt>
                <dd>@Model.Metrics.DeliveredLast24Hours</dd>
                <dt>Failed Attempts 24h</dt>
                <dd>@Model.Metrics.FailedLast24Hours</dd>
                <dt>Oldest Active</dt>
                <dd>@(Model.Metrics.OldestActiveAgeMinutes is null ? "None" : $"{Model.Metrics.OldestActiveAgeMinutes} minute(s)")</dd>
                <dt>Last Upstream Failure</dt>
                <dd>@(Model.Metrics.LastUpstreamFailureUtc is null ? "None" : $"{Model.Metrics.LastUpstreamFailureUtc.Value.ToLocalTime():g} - {Model.Metrics.LastUpstreamFailureMessage}")</dd>
            </dl>
        </section>

        <section class="panel">
            <h2>Storage And Route</h2>
            <dl class="kv">
                <dt>Outgoing Source IP</dt>
                <dd>@(Model.Metrics.OutboundRoute.Succeeded ? Model.Metrics.OutboundRoute.LocalIpAddress : Model.Metrics.OutboundRoute.Message)</dd>
                <dt>Route Target</dt>
                <dd>@(Model.Metrics.OutboundRoute.RemoteAddress ?? "Not available")</dd>
                <dt>Database</dt>
                <dd>@(Model.Metrics.IsDatabaseExternallyManaged ? Model.Metrics.DatabaseDescription : IndexModel.FormatBytes(Model.Metrics.DatabaseSizeBytes))</dd>
                <dt>Spool</dt>
                <dd>@IndexModel.FormatBytes(Model.Metrics.SpoolSizeBytes)</dd>
                <dt>Backups</dt>
                <dd>@IndexModel.FormatBytes(Model.Metrics.BackupSizeBytes)</dd>
                <dt>Backup Readiness</dt>
                <dd><span class="status-badge @(Model.Metrics.BackupReadiness.IsReady ? "status-enabled" : "severity-warning")">@(Model.Metrics.BackupReadiness.IsReady ? "Ready" : "Needs attention")</span> @Model.Metrics.BackupReadiness.Message</dd>
            </dl>
        </section>
    </div>

    <div class="surface-grid two-up">
        <section class="panel">
            <h2>Delivery Control</h2>
            <dl class="kv">
                <dt>Outbound Delivery</dt>
                <dd><span class="status-badge @(Model.RuntimeStatus.IsDeliveryPaused ? "status-disabled" : "status-enabled")">@(Model.RuntimeStatus.IsDeliveryPaused ? "Paused" : "Running")</span></dd>
                <dt>Paused By</dt>
                <dd>@Model.RuntimeStatus.DeliveryPausedBy</dd>
                <dt>Paused At</dt>
                <dd>@Model.RuntimeStatus.DeliveryPausedUtc?.ToLocalTime()</dd>
            </dl>
            <div class="actions">
                @if (Model.RuntimeStatus.IsDeliveryPaused)
                {
                    <form method="post" asp-page-handler="Resume" class="inline-form">
                        <button type="submit">Resume Delivery</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page-handler="Pause" class="inline-form">
                        <button type="submit">Pause Delivery</button>
                    </form>
                }
            </div>
        </section>

        <section class="panel">
            <h2>Runtime Status</h2>
            @{
                var smtpHeartbeat = TimeFormatter.FormatHeartbeat(Model.RuntimeStatus.SmtpListener.LastHeartbeatUtc, Model.LoadedUtc);
                var deliveryHeartbeat = TimeFormatter.FormatHeartbeat(Model.RuntimeStatus.DeliveryWorker.LastHeartbeatUtc, Model.LoadedUtc);
                var maintenanceHeartbeat = TimeFormatter.FormatHeartbeat(Model.RuntimeStatus.MaintenanceWorker.LastHeartbeatUtc, Model.LoadedUtc);
            }
            <dl class="kv">
                <dt>SMTP Listener</dt>
                <dd><span class="status-badge status-@Model.RuntimeStatus.SmtpListener.Status.ToLowerInvariant()">@Model.RuntimeStatus.SmtpListener.Status</span></dd>
                <dt>Listener Detail</dt>
                <dd>@Model.RuntimeStatus.SmtpListener.Detail</dd>
                <dt>Listener Heartbeat</dt>
                <dd><span class="status-badge @smtpHeartbeat.BadgeClass">@smtpHeartbeat.Text</span></dd>
                <dt>Delivery Worker</dt>
                <dd><span class="status-badge @(Model.RuntimeStatus.IsDeliveryPaused ? "status-disabled" : Model.RuntimeStatus.DeliveryWorker.Status == "Faulted" ? "status-failed" : "status-enabled")">@(Model.RuntimeStatus.IsDeliveryPaused ? "Paused" : Model.RuntimeStatus.DeliveryWorker.Status)</span></dd>
                <dt>Active Deliveries</dt>
                <dd>@Model.RuntimeStatus.ActiveDeliveries</dd>
                <dt>Delivery Heartbeat</dt>
                <dd><span class="status-badge @deliveryHeartbeat.BadgeClass">@deliveryHeartbeat.Text</span></dd>
                <dt>Maintenance</dt>
                <dd><span class="status-badge @(Model.RuntimeStatus.MaintenanceWorker.Status == "Faulted" ? "status-failed" : "status-enabled")">@Model.RuntimeStatus.MaintenanceWorker.Status</span></dd>
                <dt>Maintenance Heartbeat</dt>
                <dd><span class="status-badge @maintenanceHeartbeat.BadgeClass">@maintenanceHeartbeat.Text</span></dd>
                <dt>Last Cleanup</dt>
                <dd>@Model.RuntimeStatus.LastCleanupUtc?.ToLocalTime()</dd>
            </dl>
        </section>
    </div>

    <div class="surface-grid two-up">
        <section class="panel">
            <h2>Listener</h2>
            <dl class="kv">
                <dt>Bind</dt>
                <dd>@Model.Configuration.ListenerBindAddress:@Model.Configuration.ListenerPort</dd>
                <dt>Hostname</dt>
                <dd>@Model.Configuration.ListenerHostName</dd>
                <dt>STARTTLS</dt>
                <dd><span class="status-badge @(Model.Configuration.EnableStartTls ? "status-enabled" : "status-disabled")">@(Model.Configuration.EnableStartTls ? "Enabled" : "Disabled")</span></dd>
            </dl>
        </section>

        <section class="panel">
            <h2>Upstream Relay</h2>
            <dl class="kv">
                <dt>Host</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Configuration.UpstreamHost) ? "Not configured" : Model.Configuration.UpstreamHost)</dd>
                <dt>Port</dt>
                <dd>@Model.Configuration.UpstreamPort</dd>
                <dt>TLS</dt>
                <dd>@Model.Configuration.UpstreamSecureSocketOptions</dd>
                <dt>Authentication</dt>
                <dd><span class="status-badge @(Model.Configuration.UseUpstreamAuthentication ? "status-enabled" : "status-disabled")">@(Model.Configuration.UseUpstreamAuthentication ? "Enabled" : "Disabled")</span></dd>
                <dt>Timeout</dt>
                <dd>@Model.Configuration.UpstreamTimeoutSeconds seconds</dd>
            </dl>
        </section>
    </div>

    <section class="panel">
        <h2>Recent Events</h2>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Severity</th>
                        <th>Category</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.RecentEvents)
                {
                    <tr>
                        <td>@item.OccurredUtc.ToLocalTime()</td>
                        <td><span class="status-badge severity-@(item.Severity.ToString().ToLowerInvariant())">@item.Severity</span></td>
                        <td><span class="badge">@item.Category</span></td>
                        <td>@item.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>
