@page
@model Relaywright.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page">
    <header class="page-header">
        <div class="page-header-copy">
            <p class="page-eyebrow">Overview</p>
            <h1>Dashboard</h1>
            <p class="page-summary">Monitor relay health, review the active upstream configuration, and keep an eye on recent operational events without leaving the main workspace.</p>
        </div>
    </header>

    <div class="stats-grid">
        <article class="stat">
            <h2>Pending</h2>
            <strong>@Model.PendingCount</strong>
            <p>Accepted messages waiting for first delivery.</p>
        </article>
        <article class="stat">
            <h2>Retrying</h2>
            <strong>@Model.RetryCount</strong>
            <p>Messages scheduled for another upstream attempt.</p>
        </article>
        <article class="stat">
            <h2>Failed</h2>
            <strong>@Model.FailedCount</strong>
            <p>Queue items that need review or operator action.</p>
        </article>
        <article class="stat">
            <h2>Delivered Today</h2>
            <strong>@Model.DeliveredTodayCount</strong>
            <p>Successful deliveries recorded since midnight.</p>
        </article>
    </div>

    <section class="panel">
        <h2>Runtime</h2>
        <div class="stats-grid">
            <article class="stat">
                <h2>SMTP Listener</h2>
                <strong class="stat-state">@Model.RuntimeStatus.SmtpListener.Status</strong>
                <p>@Model.RuntimeStatus.SmtpListener.Detail</p>
            </article>
            <article class="stat">
                <h2>Delivery Worker</h2>
                <strong class="stat-state">@(Model.RuntimeStatus.IsDeliveryPaused ? "Paused" : Model.RuntimeStatus.DeliveryWorker.Status)</strong>
                <p>@Model.RuntimeStatus.ActiveDeliveries active delivery task(s).</p>
            </article>
            <article class="stat">
                <h2>Maintenance</h2>
                <strong class="stat-state">@Model.RuntimeStatus.MaintenanceWorker.Status</strong>
                <p>Last cleanup: @Model.RuntimeStatus.LastCleanupUtc?.ToLocalTime()</p>
            </article>
            <article class="stat">
                <h2>Delivery Control</h2>
                <strong class="stat-state">@(Model.RuntimeStatus.IsDeliveryPaused ? "Paused" : "Enabled")</strong>
                <p>@Model.RuntimeStatus.DeliveryPauseReason</p>
            </article>
        </div>
    </section>

    <div class="surface-grid two-up">
        <section class="panel">
            <h2>Listener</h2>
            <dl class="kv">
                <dt>Bind</dt>
                <dd>@Model.Configuration.ListenerBindAddress:@Model.Configuration.ListenerPort</dd>
                <dt>Hostname</dt>
                <dd>@Model.Configuration.ListenerHostName</dd>
                <dt>STARTTLS</dt>
                <dd><span class="status-badge @(Model.Configuration.EnableStartTls ? "status-enabled" : "status-disabled")">@(Model.Configuration.EnableStartTls ? "Enabled" : "Disabled")</span></dd>
            </dl>
        </section>

        <section class="panel">
            <h2>Upstream Relay</h2>
            <dl class="kv">
                <dt>Host</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Configuration.UpstreamHost) ? "Not configured" : Model.Configuration.UpstreamHost)</dd>
                <dt>Port</dt>
                <dd>@Model.Configuration.UpstreamPort</dd>
                <dt>TLS</dt>
                <dd>@Model.Configuration.UpstreamSecureSocketOptions</dd>
                <dt>Authentication</dt>
                <dd><span class="status-badge @(Model.Configuration.UseUpstreamAuthentication ? "status-enabled" : "status-disabled")">@(Model.Configuration.UseUpstreamAuthentication ? "Enabled" : "Disabled")</span></dd>
                <dt>Timeout</dt>
                <dd>@Model.Configuration.UpstreamTimeoutSeconds seconds</dd>
            </dl>
        </section>
    </div>

    <section class="panel">
        <h2>Recent Events</h2>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Severity</th>
                        <th>Category</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.RecentEvents)
                {
                    <tr>
                        <td>@item.OccurredUtc.ToLocalTime()</td>
                        <td><span class="status-badge severity-@(item.Severity.ToString().ToLowerInvariant())">@item.Severity</span></td>
                        <td><span class="badge">@item.Category</span></td>
                        <td>@item.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>
