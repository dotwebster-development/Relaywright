@using Relaywright.Web.UI
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var navState = isAuthenticated ? AppNavigation.Resolve(Context.Request.Path) : null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Relaywright</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app-shell @(isAuthenticated ? "is-authenticated" : "is-public")">
        @if (isAuthenticated && navState is not null)
        {
            <div class="app-overlay" data-nav-dismiss></div>
            <aside class="app-rail" id="app-rail">
                <div class="rail-brand">
                    <a class="rail-brand-mark" asp-page="/Index" aria-label="Relaywright home">
                        <img src="~/brand/relaywright-mark.svg" alt="" />
                    </a>
                    <div class="rail-brand-copy">
                        <p class="rail-brand-kicker">Relaywright</p>
                        <p class="rail-brand-note">Local forwarding console</p>
                    </div>
                </div>

                <nav class="rail-nav" aria-label="Primary">
                    @foreach (var navSection in navState.Sections)
                    {
                        <a asp-page="@navSection.Page"
                           class="rail-link @(navState.IsSectionActive(navSection) ? "is-active" : null)"
                           aria-current="@(navState.IsSectionActive(navSection) ? "page" : null)">
                            <span class="rail-link-label">@navSection.Label</span>
                            <span class="rail-link-note">@navSection.Description</span>
                        </a>
                    }
                </nav>

                <div class="rail-footer">
                    <div class="rail-account">
                        <p class="rail-account-label">Signed in</p>
                        <p class="rail-account-user">@User.Identity?.Name</p>
                        <form method="post" asp-page="/Account/Logout" class="rail-account-form">
                            <button type="submit" class="secondary-button">Logout</button>
                        </form>
                    </div>
                </div>
            </aside>
        }

        <div class="workspace">
            @if (isAuthenticated && navState is not null)
            {
                <nav class="section-nav" aria-label="@($"{navState.ActiveSection.Label} pages")">
                    <div class="section-nav-heading">
                        <button type="button" class="nav-toggle" data-nav-toggle aria-controls="app-rail" aria-expanded="false">
                            Menu
                        </button>
                        <div class="section-nav-label">@navState.ActiveSection.Label</div>
                    </div>
                    <div class="section-nav-items">
                        @foreach (var item in navState.ActiveSection.Items)
                        {
                            <a asp-page="@item.Page"
                               class="section-nav-link @(navState.IsItemActive(item) ? "is-active" : null)"
                               aria-current="@(navState.IsItemActive(item) ? "page" : null)">@item.Label</a>
                        }
                    </div>
                    <div class="settings-search" data-settings-search>
                        <input type="search" placeholder="Search settings" aria-label="Search settings" autocomplete="off" data-settings-search-input />
                        <div class="settings-search-results" data-settings-search-results hidden>
                            @foreach (var item in navState.SettingsSearchItems)
                            {
                                <a asp-page="@item.Page"
                                   data-settings-search-item
                                   data-settings-search-text="@($"{item.Label} {item.Group} {item.Keywords}")">
                                    <span>@item.Label</span>
                                    <small>@item.Group</small>
                                </a>
                            }
                            <div class="settings-search-empty" data-settings-search-empty hidden>No matching settings</div>
                        </div>
                    </div>
                </nav>
            }
            else
            {
                <header class="public-header">
                    <a class="public-brand" asp-page="/Index">
                        <img src="~/brand/relaywright-mark.svg" alt="" />
                        <span>Relaywright</span>
                    </a>
                </header>
            }

            <main class="content">
                <div class="content-inner">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
    <script>
        (() => {
            const root = document.documentElement;
            const toggle = document.querySelector('[data-nav-toggle]');
            const dismiss = document.querySelector('[data-nav-dismiss]');
            const rail = document.getElementById('app-rail');

            if (!toggle || !dismiss || !rail) {
                return;
            }

            const setOpen = (isOpen) => {
                root.classList.toggle('nav-open', isOpen);
                toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            };

            const close = () => setOpen(false);

            toggle.addEventListener('click', () => {
                setOpen(!root.classList.contains('nav-open'));
            });

            dismiss.addEventListener('click', close);

            rail.querySelectorAll('a').forEach((link) => {
                link.addEventListener('click', () => {
                    if (window.innerWidth <= 960) {
                        close();
                    }
                });
            });

            window.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    close();
                }
            });

            const desktopMedia = window.matchMedia('(min-width: 961px)');
            const handleDesktopChange = (event) => {
                if (event.matches) {
                    close();
                }
            };

            if (desktopMedia.addEventListener) {
                desktopMedia.addEventListener('change', handleDesktopChange);
            } else {
                desktopMedia.addListener(handleDesktopChange);
            }
        })();

        (() => {
            const root = document.querySelector('[data-settings-search]');
            if (!root) {
                return;
            }

            const input = root.querySelector('[data-settings-search-input]');
            const results = root.querySelector('[data-settings-search-results]');
            const items = Array.from(root.querySelectorAll('[data-settings-search-item]'));
            const empty = root.querySelector('[data-settings-search-empty]');

            if (!input || !results || items.length === 0) {
                return;
            }

            const normalize = (value) => value.trim().toLowerCase();
            const visibleItems = () => items.filter((item) => !item.hidden);

            const setOpen = (isOpen) => {
                results.hidden = !isOpen;
                input.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            };

            const update = () => {
                const query = normalize(input.value);
                let matchCount = 0;

                items.forEach((item) => {
                    const haystack = normalize(item.dataset.settingsSearchText ?? item.textContent ?? '');
                    const isMatch = query.length > 0 && haystack.includes(query);
                    item.hidden = !isMatch;
                    if (isMatch) {
                        matchCount++;
                    }
                });

                if (empty) {
                    empty.hidden = query.length === 0 || matchCount > 0;
                }

                setOpen(query.length > 0);
            };

            input.addEventListener('input', update);
            input.addEventListener('focus', update);
            input.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    input.value = '';
                    update();
                    input.blur();
                    return;
                }

                if (event.key === 'Enter') {
                    const first = visibleItems()[0];
                    if (first) {
                        event.preventDefault();
                        first.click();
                    }
                }
            });

            document.addEventListener('click', (event) => {
                if (!root.contains(event.target)) {
                    setOpen(false);
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
