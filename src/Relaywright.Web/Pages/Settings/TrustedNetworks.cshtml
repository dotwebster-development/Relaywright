@page "{editId?}"
@model Relaywright.Web.Pages.Settings.TrustedNetworksModel
@{
    ViewData["Title"] = "Trusted IPs";
}

<section class="page">
    <header class="page-header">
        <div class="page-header-copy">
            <p class="page-eyebrow">Settings</p>
            <h1>Trusted IPs</h1>
            <p class="page-summary">Control which printers, devices, and local systems are allowed to submit mail to the relay listener.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="surface-status flash-status" data-flash-status role="status" aria-live="polite">
            <p class="status">@Model.StatusMessage</p>
        </div>
    }

    <section class="panel">
        <h2>@(Model.Input.Id == 0 ? "Add Trusted Network" : "Edit Trusted Network")</h2>
        <form method="post" asp-page-handler="Save" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="status error"></div>
            <input asp-for="Input.Id" type="hidden" />

            <div class="settings-block-title">Identity</div>
            <div class="compact-grid">
                <label>
                    <span>CIDR / IP</span>
                    <input asp-for="Input.Cidr" />
                </label>
                <label>
                    <span>Description</span>
                    <input asp-for="Input.Description" />
                </label>
                <label>
                    <span>Owner</span>
                    <input asp-for="Input.Owner" />
                </label>
                <label>
                    <span>Location</span>
                    <input asp-for="Input.Location" />
                </label>
                <div class="toggle-field">
                    <label class="switch-control">
                        <input asp-for="Input.IsEnabled" type="checkbox" />
                        <span class="switch-control-track" aria-hidden="true"></span>
                        <span>Enabled</span>
                    </label>
                </div>
            </div>

            <div class="settings-block-title">Limits</div>
            <div class="compact-grid">
                <label>
                    <span>Max Size (Bytes)</span>
                    <input asp-for="Input.MaxMessageSizeBytes" type="number" min="1" />
                </label>
                <label>
                    <span>Max Recipients</span>
                    <input asp-for="Input.MaxRecipientsPerMessage" type="number" min="1" />
                </label>
                <label>
                    <span>Rate Limit (/Hour)</span>
                    <input asp-for="Input.RateLimitMessagesPerHour" type="number" min="1" />
                </label>
            </div>

            <div class="settings-block-title">Senders</div>
            <div class="compact-grid compact-grid-nested">
                <label>
                    <span>Allowed Senders</span>
                    <textarea asp-for="Input.AllowedSenderAddresses" rows="6" placeholder="scanner&#64;example.com&#10;&#64;example.com"></textarea>
                </label>
                <label>
                    <span>Blocked Senders</span>
                    <textarea asp-for="Input.BlockedSenderAddresses" rows="6" placeholder="blocked&#64;example.com&#10;&#64;old-domain.test"></textarea>
                </label>
            </div>

            <div class="settings-block-title">Recipients</div>
            <div class="compact-grid compact-grid-nested">
                <label>
                    <span>Allowed Domains</span>
                    <textarea asp-for="Input.AllowedRecipientDomains" rows="6" placeholder="example.com&#10;*.partner.test"></textarea>
                </label>
                <label>
                    <span>Blocked Domains</span>
                    <textarea asp-for="Input.BlockedRecipientDomains" rows="6" placeholder="external.test&#10;*.blocked.test"></textarea>
                </label>
            </div>

            <p class="field-hint">Device-specific rules are evaluated before mail is accepted. Leave fields blank to inherit the global submission policy.</p>
            <div class="actions">
                <button type="submit">Save</button>
                <a asp-page="/Settings/TrustedNetworks">Clear</a>
            </div>
        </form>
    </section>

    <section class="panel">
        <h2>Configured Networks</h2>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>CIDR</th>
                        <th>Description</th>
                        <th>Profile</th>
                        <th>Limits</th>
                        <th>Rules</th>
                        <th>Effective Policy</th>
                        <th>Enabled</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Networks)
                {
                    <tr>
                        <td>@item.Cidr</td>
                        <td>@item.Description</td>
                        <td>@TrustedNetworksModel.FormatProfile(item)</td>
                        <td>@TrustedNetworksModel.FormatLimits(item)</td>
                        <td>@TrustedNetworksModel.FormatPolicySummary(item)</td>
                        <td>@TrustedNetworksModel.FormatEffectivePolicy(Model.GetEffectivePolicy(item.Id))</td>
                        <td><span class="status-badge @(item.IsEnabled ? "status-enabled" : "status-disabled")">@(item.IsEnabled ? "Enabled" : "Disabled")</span></td>
                        <td class="row-actions">
                            <a asp-page="/Settings/TrustedNetworks" asp-route-editId="@item.Id">Edit</a>
                            <form method="post" asp-page-handler="Delete" class="inline-form" onsubmit="return confirm('Delete this trusted network?');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="secondary-button">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>
